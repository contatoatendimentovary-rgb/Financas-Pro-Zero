 <!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>FinançasPRO - Gestão Comercial Premium</title>
    <link rel="stylesheet" href="style.css">
    <link rel="manifest" href="manifest.json">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body class="dark-theme"> <header>
        <div class="header-content">
            <h1 class="logo">FinançasPRO</h1>
            <div class="header-actions">
                <button id="theme-toggle" class="btn-theme-toggle">
                    <span id="theme-icon-sun">☀️</span>
                    <span id="theme-icon-moon">🌙</span>
                </button>
                <button id="btnAuth" class="btn-auth">Entrar</button>
            </div>
        </div>
    </header>

    <main class="main-content">
        <section class="dashboard">
            <div class="card-acumulado">
                <span>Saldo Acumulado (2026)</span>
                <h2 id="saldoTotal">R$ 0,00</h2>
            </div>
            
            <div class="card-principal">
                <div class="grafico-box">
                    <canvas id="meuGrafico"></canvas>
                </div>
                <div class="resumo-mes">
                    <span>Fluxo de</span>
                    <select id="filtroMes" class="mes-select">
                        <option value="janeiro">Janeiro</option>
                        <option value="fevereiro">Fevereiro</option>
                        <option value="março">Março</option>
                        <option value="abril" selected>Abril</option>
                        <option value="maio">Maio</option>
                        <option value="junho">Junho</option>
                        <option value="julho">Julho</option>
                        <option value="agosto">Agosto</option>
                        <option value="setembro">Setembro</option>
                        <option value="outubro">Outubro</option>
                        <option value="novembro">Novembro</option>
                        <option value="dezembro">Dezembro</option>
                    </select>
                    <h3 id="saldoMes">R$ 0,00</h3>
                </div>
            </div>
        </section>

        <ul id="lista" class="transacoes-lista">
            </ul>
    </main>

    <nav class="bottom-bar">
        <button id="abrirModal" class="btn-quick-add">+</button>
    </nav>

    <div id="modal" class="modal-overlay">
        <div class="modal-container bottom-sheet">
            <div class="modal-handle"></div>
            <h3 class="modal-title">Novo Lançamento</h3>
            
            <input type="text" id="desc" placeholder="Descrição (Ex: Salário, Aluguel)">
            <input type="number" id="valor" placeholder="Valor R$">
            
            <div class="input-group">
                <label>Categoria:</label>
                <select id="categoria">
                    <option value="🏠 Moradia">Moradia</option>
                    <option value="🍔 Alimentação">Alimentação</option>
                    <option value="🚗 Transporte">Transporte</option>
                    <option value="🎭 Lazer">Lazer</option>
                    <option value="💰 Salário">Salário/Renda</option>
                    <option value="🛠️ Outros">Outros</option>
                </select>
            </div>

            <div class="input-group">
                <label>Tipo:</label>
                <select id="tipo">
                    <option value="entrada">Entrada (+)</option>
                    <option value="saida">Saída (-)</option>
                </select>
            </div>

            <div class="modal-btns">
                <button id="btnSalvar" class="confirmar">Salvar</button>
                <button id="btnFechar" class="cancelar">Fechar</button>
            </div>
        </div>
    </div>

    <script src="script.js"></script>
    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-app.js";
        import { getAuth, GoogleAuthProvider, signInWithPopup, onAuthStateChanged } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-auth.js";
        import { getFirestore, doc, setDoc, getDoc, collection, getDocs } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-firestore.js";

        const firebaseConfig = {
            apiKey: "AIzaSyA6C8n-wiKv6kp2Q7Y99D2GEL2fg_0SPVE",
            authDomain: "financaspro-1e0e8.firebaseapp.com",
            projectId: "financaspro-1e0e8",
            storageBucket: "financaspro-1e0e8.firebasestorage.app",
            messagingSenderId: "659521706556",
            appId: "1:659521706556:web:86f2174c4c8a89335ac139"
        };

        const app = initializeApp(firebaseConfig);
        window.auth = getAuth(app);
        window.db = getFirestore(app);
        window.doc = doc;
        window.setDoc = setDoc;
        window.getDoc = getDoc;
        window.collection = collection;
        window.getDocs = getDocs;
        
        const provider = new GoogleAuthProvider();
        window.loginGoogle = () => signInWithPopup(window.auth, provider).then(() => location.reload());

        onAuthStateChanged(window.auth, (user) => {
            const btn = document.getElementById('btnAuth');
            if (user) {
                btn.innerText = "Sair";
                btn.onclick = () => window.auth.signOut().then(() => location.reload());
            } else {
                btn.innerText = "Entrar";
                btn.onclick = window.loginGoogle;
            }
        });
    </script>
</body>
</html>
